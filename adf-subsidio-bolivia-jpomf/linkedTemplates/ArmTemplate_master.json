{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-subsidio-bolivia-jpomf"
		},
		"ls_blob_subsidio_connectionString": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"connectionString\"de \"ls_blob_subsidio\""
		},
		"ls_sql_dw_subsidio_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"ls_sql_dw_subsidio\""
		},
		"ls_sql_dw_subsidio_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-srv-subsidio-jpomf.database.windows.net"
		},
		"ls_sql_dw_subsidio_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "dw_subsidio_bolivia"
		},
		"ls_sql_dw_subsidio_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI de la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas."
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Token de SAS para la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-subsidio-bolivia-jpomf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_blob_subsidio_connectionString": {
						"value": "[parameters('ls_blob_subsidio_connectionString')]"
					},
					"ls_sql_dw_subsidio_password": {
						"value": "[parameters('ls_sql_dw_subsidio_password')]"
					},
					"ls_sql_dw_subsidio_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_dw_subsidio_properties_typeProperties_server')]"
					},
					"ls_sql_dw_subsidio_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_dw_subsidio_properties_typeProperties_database')]"
					},
					"ls_sql_dw_subsidio_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_dw_subsidio_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-subsidio-bolivia-jpomf_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-subsidio-bolivia-jpomf_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-subsidio-bolivia-jpomf_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-subsidio-bolivia-jpomf_ArmTemplate_1')]"
			]
		},
		{
			"name": "adf-subsidio-bolivia-jpomf_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-subsidio-bolivia-jpomf_ArmTemplate_2')]"
			]
		},
		{
			"name": "adf-subsidio-bolivia-jpomf_ArmTemplate_4",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_4.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-subsidio-bolivia-jpomf_ArmTemplate_3')]"
			]
		}
	]
}