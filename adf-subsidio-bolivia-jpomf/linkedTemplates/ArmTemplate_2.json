		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_to_silver_as_almacenes')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "silver"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_csv_bronze_as_almacenes",
								"type": "DatasetReference"
							},
							"name": "sourceAlmacenes"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_csv_silver_as_almacenes",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          almacen_id as string,",
						"          nombre as string,",
						"          municipio as string,",
						"          departamento as string,",
						"          direccion as string,",
						"          capacidad_m3 as string,",
						"          estado as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> sourceAlmacenes",
						"sourceAlmacenes derive(almacen_id = toInteger(almacen_id),",
						"          nombre = trim(nombre),",
						"          municipio = trim(municipio),",
						"          departamento = upper(trim(departamento)),",
						"          direccion = trim(direccion),",
						"          capacidad_m3 = toInteger(capacidad_m3),",
						"          estado = upper(trim(estado))) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['as_almacenes.csv'],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_to_silver_as_despachos')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "silver"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_csv_bronze_as_despachos",
								"type": "DatasetReference"
							},
							"name": "sourceDespachos"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_csv_silver_as_despachos",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          despacho_id as string,",
						"          recepcion_id as string,",
						"          nro_lote as string,",
						"          almacen_id as string,",
						"          transportista_id as string,",
						"          vehiculo_id as string,",
						"          fecha_despacho as string,",
						"          cantidad_despachada as string,",
						"          centro_destino as string,",
						"          estado as string,",
						"          responsable as string,",
						"          nro_guia_despacho as string,",
						"          fecha_llegada as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> sourceDespachos",
						"sourceDespachos derive(despacho_id = toInteger(despacho_id),",
						"          recepcion_id = toInteger(recepcion_id),",
						"          nro_lote = trim(nro_lote),",
						"          almacen_id = toInteger(almacen_id),",
						"          transportista_id = toInteger(transportista_id),",
						"          vehiculo_id = toInteger(vehiculo_id),",
						"          fecha_despacho = coalesce(     toDate(fecha_despacho,'yyyy-MM-dd'),     toDate(fecha_despacho,'dd-MM-yyyy'),     toDate(fecha_despacho,'MM/dd/yyyy'),     toDate(fecha_despacho,'dd/MM/yyyy') ),",
						"          cantidad_despachada = toInteger(cantidad_despachada),",
						"          centro_destino = trim(centro_destino),",
						"          estado = case(upper(trim(estado)) == 'DEESPACHADO', 'DESPACHADO', upper(trim(estado))),",
						"          responsable = trim(responsable),",
						"          nro_guia_despacho = trim(nro_guia_despacho),",
						"          fecha_llegada = toDate(toString(fecha_llegada), \"yyyy-MM-dd\")) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['as_despachos.csv'],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_to_silver_as_recepciones')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
