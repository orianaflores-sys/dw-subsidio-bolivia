		{
			"name": "[concat(parameters('factoryName'), '/pl_silver_csv_to_sql')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "copy_bja_inscripciones",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "DelimitedTextSource",
								"storeSettings": {
									"type": "AzureBlobStorageReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "DelimitedTextReadSettings"
								}
							},
							"sink": {
								"type": "AzureSqlSink",
								"writeBehavior": "insert",
								"sqlWriterUseTableLock": false
							},
							"enableStaging": false,
							"translator": {
								"type": "TabularTranslator",
								"mappings": [
									{
										"source": {
											"name": "inscripcion_id",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "inscripcion_id"
										}
									},
									{
										"source": {
											"name": "establecimiento_id",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "establecimiento_id"
										}
									},
									{
										"source": {
											"name": "fecha_inscripcion",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "fecha_inscripcion"
										}
									},
									{
										"source": {
											"name": "semana_gestacion",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "semana_gestacion"
										}
									},
									{
										"source": {
											"name": "estado",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "estado"
										}
									},
									{
										"source": {
											"name": "ci_beneficiaria",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "ci_beneficiaria"
										}
									}
								],
								"typeConversion": true,
								"typeConversionSettings": {
									"allowDataTruncation": true,
									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "ds_csv_silver_bja_inscripciones",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "ds_sql_silver",
								"type": "DatasetReference",
								"parameters": {
									"esquema": "silver",
									"tabla": "bja_inscripciones"
								}
							}
						]
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"folder": {
					"name": "gold"
				},
				"annotations": []
			},
