		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_to_silver_sup_entregas')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "silver"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_csv_bronze_sup_entregas",
								"type": "DatasetReference"
							},
							"name": "sourceEntregas"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_csv_silver_sup_entregas",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          entrega_id as string,",
						"          boleta_id as string,",
						"          ci_beneficiaria as string,",
						"          establecimiento_id as string,",
						"          paquete_id as string,",
						"          paquete_nombre as string,",
						"          fecha_entrega as string,",
						"          lote_produccion as string,",
						"          peso_paquete_kg as string,",
						"          fecha_proxima_entrega as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> sourceEntregas",
						"sourceEntregas derive(entrega_id = toInteger(entrega_id),",
						"          boleta_id = toInteger(boleta_id),",
						"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
						"          establecimiento_id = toInteger(establecimiento_id),",
						"          paquete_id = toInteger(paquete_id),",
						"          paquete_nombre = trim(paquete_nombre),",
						"          fecha_entrega = coalesce(\r",
						"    toDate(fecha_entrega,'yyyy-MM-dd'),\r",
						"    toDate(fecha_entrega,'dd-MM-yyyy'),\r",
						"    toDate(fecha_entrega,'MM/dd/yyyy'),\r",
						"    toDate(fecha_entrega,'dd/MM/yyyy')\r",
						"),",
						"          lote_produccion = iif(isNull(lote_produccion) || lote_produccion == '', toString(null()), trim(lote_produccion)),",
						"          peso_paquete_kg = toDecimal(peso_paquete_kg),",
						"          fecha_proxima_entrega = iif(\r",
						"    isNull(fecha_proxima_entrega) || trim(toString(fecha_proxima_entrega)) == '',\r",
						"    toDate(null()),\r",
						"    coalesce(\r",
						"        toDate(toString(fecha_proxima_entrega),'yyyy-MM-dd'),\r",
						"        toDate(toString(fecha_proxima_entrega),'dd-MM-yyyy'),\r",
						"        toDate(toString(fecha_proxima_entrega),'MM/dd/yyyy'),\r",
						"        toDate(toString(fecha_proxima_entrega),'dd/MM/yyyy')\r",
						"    )\r",
						")) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['sup_entregas.csv'],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/df_bronze_to_silver_sup_establecimientos')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"folder": {
					"name": "silver"
				},
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_csv_bronze_sup_establecimientos",
								"type": "DatasetReference"
							},
							"name": "sourceEstablecimientos"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_csv_silver_sup_establecimientos",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          establecimiento_id as string,",
						"          codigo_snis as string,",
						"          nombre as string,",
						"          tipo as string,",
						"          nivel_atencion as string,",
						"          municipio as string,",
						"          departamento as string,",
						"          red_salud as string,",
						"          estado as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> sourceEstablecimientos",
						"sourceEstablecimientos derive(establecimiento_id = toInteger(establecimiento_id),",
						"          codigo_snis = trim(codigo_snis),",
						"          nombre = trim(nombre),",
						"          tipo = upper(trim(tipo)),",
						"          nivel_atencion = trim(nivel_atencion),",
						"          municipio = trim(municipio),",
						"          departamento = case(upper(trim(departamento))=='LP','LA PAZ',upper(trim(departamento))=='CB','COCHABAMBA',upper(trim(departamento))=='SC','SANTA CRUZ',upper(trim(departamento))=='OR','ORURO',upper(trim(departamento))=='PT','POTOSI',upper(trim(departamento))=='TJ','TARIJA',upper(trim(departamento))=='CH','CHUQUISACA',upper(trim(departamento))=='BN','BENI',upper(trim(departamento))=='PD','PANDO',upper(trim(departamento))),",
						"          red_salud = trim(red_salud),",
						"          estado = upper(trim(estado))) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['sup_establecimientos.csv'],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
