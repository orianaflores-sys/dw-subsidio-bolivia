{
	"name": "df_bronze_to_silver_spl_empleadores",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_spl_empleadores",
						"type": "DatasetReference"
					},
					"name": "sourceEmpleadores"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_spl_empleadores",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          empleador_id as string,",
				"          nit as string,",
				"          razon_social as string,",
				"          tipo as string,",
				"          nro_patronal as string,",
				"          municipio as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceEmpleadores",
				"sourceEmpleadores derive(empleador_id = toInteger(empleador_id),",
				"          nit = trim(nit),",
				"          razon_social = trim(razon_social),",
				"          tipo = upper(trim(tipo)),",
				"          nro_patronal = trim(nro_patronal),",
				"          municipio = trim(municipio)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['spl_empleadores.csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}