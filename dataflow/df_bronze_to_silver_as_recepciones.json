{
	"name": "df_bronze_to_silver_as_recepciones",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_as_recepciones",
						"type": "DatasetReference"
					},
					"name": "sourceRecepciones"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_as_recepciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          recepcion_id as string,",
				"          nro_lote as string,",
				"          almacen_id as string,",
				"          transportista_id as string,",
				"          vehiculo_id as string,",
				"          fecha_recepcion as string,",
				"          cantidad_recibida as string,",
				"          unidad as string,",
				"          condicion as string,",
				"          estado as string,",
				"          responsable as string,",
				"          nro_guia_remision as string,",
				"          temperatura_llegada as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceRecepciones",
				"sourceRecepciones derive(recepcion_id = toInteger(recepcion_id),",
				"          nro_lote = trim(nro_lote),",
				"          almacen_id = toInteger(almacen_id),",
				"          transportista_id = toInteger(transportista_id),",
				"          vehiculo_id = toInteger(vehiculo_id),",
				"          fecha_recepcion = coalesce(\r",
				"    toDate(fecha_recepcion,'yyyy-MM-dd'),\r",
				"    toDate(fecha_recepcion,'dd-MM-yyyy'),\r",
				"    toDate(fecha_recepcion,'MM/dd/yyyy'),\r",
				"    toDate(fecha_recepcion,'dd/MM/yyyy')\r",
				"),",
				"          cantidad_recibida = toInteger(cantidad_recibida),",
				"          unidad = case(\r",
				"    lower(trim(unidad)) == 'cajas', 'cajas',\r",
				"    lower(trim(unidad)) == 'caja', 'cajas',\r",
				"    lower(trim(unidad)) == 'kg', 'kg',\r",
				"    lower(trim(unidad)) == 'kilos', 'kg',\r",
				"    lower(trim(unidad)) == 'kilogramos', 'kg',\r",
				"    lower(trim(unidad)) == 'unidades', 'unidades',\r",
				"    lower(trim(unidad)) == 'unidad', 'unidades',\r",
				"    lower(trim(unidad)) == 'litros', 'litros',\r",
				"    lower(trim(unidad)) == 'litro', 'litros',\r",
				"    lower(trim(unidad)) == 'paquetes', 'paquetes',\r",
				"    lower(trim(unidad)) == 'paquete', 'paquetes',\r",
				"    lower(trim(unidad))\r",
				"),",
				"          condicion = upper(trim(condicion)),",
				"          estado = upper(trim(estado)),",
				"          responsable = trim(responsable),",
				"          nro_guia_remision = trim(nro_guia_remision),",
				"          temperatura_llegada = toInteger(temperatura_llegada)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}