{
	"name": "df_bronze_to_silver_spl_entregas_agencias",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_spl_entregas_agencia",
						"type": "DatasetReference"
					},
					"name": "sourceEntregasAgencias"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_spl_entregas_agencias",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_ag_id as string,",
				"          asignacion_id as string,",
				"          ci_beneficiaria as string,",
				"          fecha_entrega as string,",
				"          productos as string,",
				"          lote as string,",
				"          peso_kg as string,",
				"          punto_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceEntregasAgencias",
				"sourceEntregasAgencias derive(entrega_ag_id = toInteger(entrega_ag_id),",
				"          asignacion_id = toInteger(asignacion_id),",
				"          ci_beneficiaria = replace(trim(ci_beneficiaria), '-', ''),",
				"          fecha_entrega = iif(isNull(fecha_entrega) || fecha_entrega == '', toDate(null()), iif(instr(fecha_entrega, '/') > 0, toDate(fecha_entrega, 'dd/MM/yyyy'), toDate(fecha_entrega, 'yyyy-MM-dd'))),",
				"          productos = upper(trim(toString(productos))),",
				"          lote = trim(lote),",
				"          peso_kg = toDecimal(peso_kg),",
				"          punto_entrega = initCap(lower(trim(punto_entrega)))) ~> derivedColumn1",
				"derivedColumn1 derive(punto_entrega = case(\r",
				"    like(upper(toString(punto_entrega)), \"%COCH%\") && like(upper(toString(punto_entrega)), \"%NORT%\"),\r",
				"    \"Centro Distribución Cochabamba - Zona Norte\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%COCH%\") && like(upper(toString(punto_entrega)), \"%CENT%\"),\r",
				"    \"Centro Distribución Cochabamba - Central\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%ALTO%\") && like(upper(toString(punto_entrega)), \"%16%\"),\r",
				"    \"Centro Distribución El Alto - 16 De Julio\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%ALTO%\") && (like(upper(toString(punto_entrega)), \"%RIO%\") || like(upper(toString(punto_entrega)), \"%RÍO%\") || like(upper(toString(punto_entrega)), \"%SECO%\")),\r",
				"    \"Centro Distribución El Alto - Río Seco\",\r",
				"\r",
				"    (like(upper(toString(punto_entrega)), \"%LA PAZ%\") || like(upper(toString(punto_entrega)), \"%LAP AZ%\") || like(upper(toString(punto_entrega)), \"%LA APZ%\") || like(upper(toString(punto_entrega)), \"%LA AZ%\")) && (like(upper(toString(punto_entrega)), \"%SAN%\") || like(upper(toString(punto_entrega)), \"%AN PEDRO%\")),\r",
				"    \"Centro Distribución La Paz - San Pedro\",\r",
				"\r",
				"    (like(upper(toString(punto_entrega)), \"%LA PAZ%\") || like(upper(toString(punto_entrega)), \"%LA APZ%\") || like(upper(toString(punto_entrega)), \"%LA AZ%\")) && (like(upper(toString(punto_entrega)), \"%SUR%\") || like(upper(toString(punto_entrega)), \"%ZONAS UR%\")),\r",
				"    \"Centro Distribución La Paz - Zona Sur\",\r",
				"\r",
				"    (like(upper(toString(punto_entrega)), \"%SANTA%\") || like(upper(toString(punto_entrega)), \"%SATA%\") || like(upper(toString(punto_entrega)), \"%SNATA%\")) && (like(upper(toString(punto_entrega)), \"%EQUI%\") || like(upper(toString(punto_entrega)), \"%QEUIP%\")),\r",
				"    \"Centro Distribución Santa Cruz - Equipetrol\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%PLAN%\") || like(upper(toString(punto_entrega)), \"%3000%\"),\r",
				"    \"Centro Distribución Santa Cruz - Plan 3000\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%QUILL%\"),\r",
				"    \"Centro Distribución Quillacollo\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%MONTE%\") || like(upper(toString(punto_entrega)), \"%MNOTERO%\") || like(upper(toString(punto_entrega)), \"%MOTERO%\"),\r",
				"    \"Centro Distribución Montero\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%ORU%\") || like(upper(toString(punto_entrega)), \"%OOR%\") || like(upper(toString(punto_entrega)), \"%ORRO%\"),\r",
				"    \"Centro Distribución Oruro\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%POT%\") || like(upper(toString(punto_entrega)), \"%POOS%\") || like(upper(toString(punto_entrega)), \"%PTOO%\"),\r",
				"    \"Centro Distribución Potosí\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%TAR%\") || like(upper(toString(punto_entrega)), \"%ARIJA%\"),\r",
				"    \"Centro Distribución Tarija\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%SUCRE%\") || like(upper(toString(punto_entrega)), \"%SUCR%\") || like(upper(toString(punto_entrega)), \"%UCRE%\"),\r",
				"    \"Centro Distribución Sucre\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%TRIN%\"),\r",
				"    \"Centro Distribución Trinidad\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%COBI%\"),\r",
				"    \"Centro Distribución Cobija\",\r",
				"\r",
				"    like(upper(toString(punto_entrega)), \"%YACUI%\"),\r",
				"    \"Centro Distribución Yacuiba\",\r",
				"\r",
				"    initCap(lower(trim(toString(punto_entrega))))\r",
				")) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['spl_entregas_agencia.csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}