{
	"name": "df_bronze_to_silver_spl_supermercados",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_spl_supermercados",
						"type": "DatasetReference"
					},
					"name": "sourceSupermercados"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_spl_supermercados",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Cadena as string,",
				"          Sucursal as string,",
				"          Municipio as string,",
				"          {Dirección} as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceSupermercados",
				"sourceSupermercados derive(ID = toInteger(ID),",
				"          Cadena = trim(Cadena),",
				"          Sucursal = trim(Sucursal),",
				"          Municipio = trim(Municipio),",
				"          Estado = upper(trim(Estado)),",
				"          {Dirección} = trim({Dirección})) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          id_supermercado = ID,",
				"          cadena = Cadena,",
				"          sucursal = Sucursal,",
				"          municipio = Municipio,",
				"          {dirección} = {Dirección},",
				"          estado = Estado",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['spl_supermercados.csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}