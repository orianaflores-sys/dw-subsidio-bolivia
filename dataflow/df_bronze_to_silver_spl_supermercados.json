{
	"name": "df_bronze_to_silver_spl_supermercados",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_spl_supermercados",
						"type": "DatasetReference"
					},
					"name": "sourceSupermercados"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Cadena as string,",
				"          Sucursal as string,",
				"          Municipio as string,",
				"          {Dirección} as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceSupermercados",
				"sourceSupermercados derive(ID = toInteger(ID),",
				"          Cadena = trim(Cadena),",
				"          Sucursal = trim(Sucursal),",
				"          Municipio = trim(Municipio),",
				"          {Dirección} = ERROR_FUNCTION(''),",
				"          columna6 = ERROR_FUNCTION('')) ~> derivedColumn1"
			]
		}
	}
}