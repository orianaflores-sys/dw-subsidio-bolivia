{
	"name": "df_silver_to_gold_dim_establecimiento",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "sourceBjaEst"
				},
				{
					"dataset": {
						"referenceName": "ds_csv_silver_sup_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sourceSupEst"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "union1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as short,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceBjaEst",
				"source(output(",
				"          establecimiento_id as short,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceSupEst",
				"sourceBjaEst derive(sistema_origen = 'BJA') ~> derivedColumn1",
				"sourceSupEst derive(sistema_origen = 'SUP') ~> derivedColumn2",
				"derivedColumn1, derivedColumn2 union(byName: true)~> union1",
				"union1 select(mapColumn(",
				"          establecimiento_id,",
				"          codigo_snis,",
				"          nombre,",
				"          tipo,",
				"          nivel_atencion,",
				"          municipio,",
				"          departamento,",
				"          red_salud,",
				"          sistema_origen",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          codigo_snis,",
				"          nombre,",
				"          tipo,",
				"          nivel_atencion,",
				"          municipio,",
				"          departamento,",
				"          red_salud,",
				"          sistema_origen",
				"     )) ~> sink1"
			]
		}
	}
}