{
	"name": "df_bronze_to_silver_bja_establecimientos_salud",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_bronze_bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "sourceEstablecimientosSalud"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceEstablecimientosSalud",
				"sourceEstablecimientosSalud derive(establecimiento_id = toInteger(establecimiento_id),",
				"          codigo_snis = trim(codigo_snis),",
				"          nombre = trim(nombre),",
				"          tipo = upper(trim(tipo)),",
				"          nivel_atencion = trim(nivel_atencion),",
				"          municipio = trim(municipio),",
				"          departamento = iif(\r",
				"    upper(trim(departamento)) == \"LP\" || upper(trim(departamento)) == \"LA PAZ\",\r",
				"    \"LA PAZ\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"CB\" || upper(trim(departamento)) == \"COCHABAMBA\",\r",
				"    \"COCHABAMBA\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"SC\" || upper(trim(departamento)) == \"SANTA CRUZ\",\r",
				"    \"SANTA CRUZ\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"OR\" || upper(trim(departamento)) == \"ORURO\",\r",
				"    \"ORURO\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"TJ\" || upper(trim(departamento)) == \"TARIJA\",\r",
				"    \"TARIJA\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"CH\" || upper(trim(departamento)) == \"CHUQUISACA\",\r",
				"    \"CHUQUISACA\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"PT\" || upper(trim(departamento)) == \"POTOSI\",\r",
				"    \"POTOSI\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"BN\" || upper(trim(departamento)) == \"BENI\",\r",
				"    \"BENI\",\r",
				"\r",
				"iif(\r",
				"    upper(trim(departamento)) == \"PD\" || upper(trim(departamento)) == \"PANDO\",\r",
				"    \"PANDO\",\r",
				"\r",
				"upper(trim(departamento))\r",
				"))))))))),",
				"          red_salud = trim(red_salud),",
				"          estado = upper(trim(estado))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['bja_establecimientos_salud.csv'],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}