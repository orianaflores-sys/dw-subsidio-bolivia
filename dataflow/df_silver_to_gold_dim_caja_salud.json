{
	"name": "df_silver_to_gold_dim_caja_salud",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_csv_silver_spl_cajas",
						"type": "DatasetReference"
					},
					"name": "sourceCajas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sql_gold",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_caja as short,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCajas",
				"sourceCajas select(mapColumn(",
				"          id_caja,",
				"          nombre,",
				"          sigla,",
				"          tipo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_caja,",
				"          nombre,",
				"          sigla,",
				"          tipo",
				"     )) ~> sink1"
			]
		}
	}
}